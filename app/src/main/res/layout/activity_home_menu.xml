<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#D32F2F"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="B&amp;B FastFood"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnCarrito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carrito"
            android:backgroundTint="#FFFFFF"
            android:textColor="#D32F2F"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuestro Menu"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hamburguesas"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnHamburguesaClasica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hamburguesa Clasica - $15.000"
                android:backgroundTint="#FFEBEE"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnHamburguesaEspecial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hamburguesa Especial - $22.000"
                android:backgroundTint="#FFEBEE"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perros Calientes"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnPerroSencillo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Perro Sencillo - $8.000"
                android:backgroundTint="#FFEBEE"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnPerroEspecial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Perro Especial - $14.000"
                android:backgroundTint="#FFEBEE"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Combos"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnCombo1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Combo 1 - Hamburguesa + Bebida - $20.000"
                android:backgroundTint="#FFEBEE"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnCombo2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Combo 2 - Perro + Papas + Bebida - $18.000"
                android:backgroundTint="#FFEBEE"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="#D32F2F"
        app:itemTextColor="#D32F2F"/>

</LinearLayout>