<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="12dp"
    android:layout_margin="8dp"
    android:elevation="2dp">

    <!-- Fila superior: ID del pedido y estado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvItemPedidoId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pedido #1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

        <TextView
            android:id="@+id/tvItemEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="En preparacion"
            android:textSize="13sp"
            android:textColor="#388E3C"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Fecha del pedido -->
    <TextView
        android:id="@+id/tvItemFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01/01/2025 12:00"
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginBottom="6dp"/>

    <!-- Resumen de items -->
    <TextView
        android:id="@+id/tvItemProductos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1x Hamburguesa Clasica"
        android:textSize="13sp"
        android:textColor="#424242"
        android:layout_marginBottom="6dp"/>

    <!-- Fila inferior: total y metodo de pago -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvItemTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total: $15.000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"/>

        <TextView
            android:id="@+id/tvItemMetodoPago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Efectivo"
            android:textSize="12sp"
            android:textColor="#757575"/>

    </LinearLayout>

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="10dp"/>

</LinearLayout>
