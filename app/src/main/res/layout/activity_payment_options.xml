<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#D32F2F"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnVolverDireccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_flecha_atras"
            android:backgroundTint="#D32F2F"
            android:contentDescription="Volver"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Metodo de pago"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona como quieres pagar:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="24dp"/>

        <RadioGroup
            android:id="@+id/radioGroupPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioEfectivo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pago contra entrega (efectivo)"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <RadioButton
                android:id="@+id/radioTransferencia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transferencia bancaria"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <RadioButton
                android:id="@+id/radioPuntos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Canjear puntos de fidelidad"
                android:textSize="15sp"/>

        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen del pedido:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvResumenPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvTotalPagar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total a pagar: $15.000"
            android:textSize="18sp"
            android:textColor="#D32F2F"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvPuntosDisponibles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Puntos disponibles: 150 puntos"
            android:textSize="14sp"
            android:textColor="#388E3C"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historial de pagos guardado en SQLite"
            android:textSize="12sp"
            android:textColor="#BDBDBD"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnRealizarPedido"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Realizar pedido"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:layout_margin="16dp"/>

</LinearLayout>